(in-package :minimera)

(defun dump-pixels (array)
  (destructuring-bind (width height) (array-dimensions array)
    (dotimes (y height)
      (dotimes (x width)
        (format t "~A" (if (plusp (aref array x y)) "█" "."))) (terpri))))

(defun subarr (array x y width height)
  (let ((result (make-array (list width height))))
    (dotimes (dx width)
      (dotimes (dy height)
        (setf (aref result dx dy)
              (aref array (+ x dx) (+ y dy)))))
    result))

(defun load-font (path h &rest glyphs)
  (let ((data (netpbm:read-from-file path))
        (result (make-hash-table)))
    (dolist (glyph glyphs)
      (destructuring-bind (char x y w &optional (h h)) glyph
        (let ((pixels (subarr data x y w h)))
          ;; (terpri)
          ;; (pr char)
          ;; (dump-pixels pixels)
          (setf (gethash char result) pixels))))
    result))

